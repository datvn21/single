{
  "expo": {
    "name": "Single?",
    "slug": "single",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "single",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.whojsdat.single",
      "adaptiveIcon": {
        "backgroundColor": "#051F20",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#051F20",
          "dark": {
            "backgroundColor": "#051F20"
          }
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#051F20"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Single to save photos to your library.",
          "savePhotosPermission": "Allow Single to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      ["react-native-android-widget", {
        "widgets": [
          {
            "name": "SingleWidget",
            "label": "Single? Check-in",
            "description": "Hiển thị check-in mới nhất",
            "minWidth": "250dp",
            "minHeight": "110dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "resizeMode": "horizontal|vertical",
            "widgetFeatures": "reconfigurable",
            "updatePeriodMillis": 1800000
          }
        ]
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbbe28e1-9b16-44a0-8d05-432aa29c32f9"
      },
      "googleDrive": {
        "webClientId": "490870699972-0vi8e7079pjd6f8ad6g8bib924ps5to4.apps.googleusercontent.com",
        "iosClientId": "",
        "androidClientId": "490870699972-s1psacrtpots29lp2sdhne5e9sjkqls0.apps.googleusercontent.com",
        "expoClientId": "490870699972-0vi8e7079pjd6f8ad6g8bib924ps5to4.apps.googleusercontent.com"
      }
    }
  }
}
